{
  "name": "@hitesh23k/lighter-sdk",
  "version": "0.4.0",
  "description": "Lighter (zkLighter) TypeScript SDK for perpetual futures trading: place orders, bracket orders (TP/SL), stream real-time market data over WebSocket, onboard wallets, and sign transactions. Zero-dependency, runs in Node and the browser.",
  "license": "Apache-2.0",
  "author": "hitesh23k",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/index.browser.d.ts",
      "import": "./dist/index.browser.mjs",
      "default": "./dist/index.browser.mjs"
    },
    "./lighterSigner.wasm": "./dist/lighterSigner.wasm",
    "./wasm_exec.js": "./dist/wasm_exec.js"
  },
  "files": [
    "dist",
    "NOTICE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-wasm.mjs",
    "build:wasm": "bash scripts/build-wasm.sh",
    "checksum": "node scripts/verify-checksums.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run checksum && npm run typecheck && npm run build && npm test"
  },
  "keywords": [
    "lighter",
    "zklighter",
    "lighter-protocol",
    "lighter-exchange",
    "lighter-sdk",
    "perp",
    "perps",
    "perpetuals",
    "perpetual-futures",
    "futures",
    "derivatives",
    "dex",
    "defi",
    "trading",
    "trading-bot",
    "crypto",
    "cryptocurrency",
    "orderbook",
    "websocket",
    "ethereum",
    "layer2",
    "zk-rollup",
    "zero-knowledge",
    "wasm",
    "signer",
    "typescript",
    "sdk",
    "api",
    "robinhood",
    "elliot"
  ],
  "homepage": "https://www.npmjs.com/package/@hitesh23k/lighter-sdk",
  "optionalDependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
